# NanoClaw Configuration
# Copy to .env and fill in required values.
# All values shown are defaults (uncomment and change as needed).

# ── Authentication / Channels ────────────────────────────────────────────────
# Channel-specific tokens are loaded from data/env/env by the credential proxy.
# TELEGRAM_BOT_TOKEN=

# ── Assistant Identity ───────────────────────────────────────────────────────
# ASSISTANT_NAME=Andy
# ASSISTANT_HAS_OWN_NUMBER=false

# ── Runtime ──────────────────────────────────────────────────────────────────
# NANOCLAW_RUNTIME=              # auto-detected: jail (FreeBSD), apple (macOS), docker (Linux)
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000      # Agent timeout in ms (default 30min, min 1min, max 2hr)
# CONTAINER_MAX_OUTPUT_SIZE=10485760  # Max agent output in bytes (default 10MB, min 1MB, max 100MB)
# IDLE_TIMEOUT=1800000           # Container idle timeout in ms (default 30min, min 1min, max 2hr)
# MAX_CONCURRENT_CONTAINERS=5   # Max parallel containers (min 1, max 50)

# ── Credential Proxy ────────────────────────────────────────────────────────
# CREDENTIAL_PROXY_PORT=3001     # Port for the credential proxy (min 1024, max 65535)
# CREDENTIAL_PROXY_HOST=         # Bind address (auto-detected per runtime)

# ── Jail Runtime (FreeBSD only) ─────────────────────────────────────────────
# NANOCLAW_JAIL_NETWORK_MODE=restricted  # "restricted" (vnet+pf) or "inherit" (host network)
# NANOCLAW_JAIL_MEMORY_LIMIT=2G  # Memory limit per jail (rctl)
# NANOCLAW_JAIL_MAXPROC=100      # Max processes per jail (rctl)
# NANOCLAW_JAIL_PCPU=80          # CPU percentage limit per jail (rctl)
# NANOCLAW_MAX_EPAIRS=200        # Max epair interfaces (min 1, max 255)
# NANOCLAW_MAX_JAILS=50          # Max concurrent jails (min 1, max 100)

# ── Jail Timeouts (ms) ──────────────────────────────────────────────────────
# JAIL_EXEC_TIMEOUT=30000        # sudo exec operations (default 30s, min 5s, max 5min)
# JAIL_CREATE_TIMEOUT=30000      # ZFS clone during jail creation (default 30s, min 5s, max 5min)
# JAIL_STOP_TIMEOUT=15000        # Graceful jail stop (default 15s, min 5s, max 2min)
# JAIL_FORCE_STOP_TIMEOUT=10000  # Force jail stop (default 10s, min 5s, max 1min)
# JAIL_QUICK_OP_TIMEOUT=5000     # Quick ops: unmount, epair destroy (default 5s, min 1s, max 30s)

# ── Health & Metrics ────────────────────────────────────────────────────────
# HEALTH_ENABLED=true            # /health endpoint (on by default)
# METRICS_ENABLED=false          # /metrics Prometheus endpoint (opt-in)
# METRICS_PORT=9090              # Port for health/metrics server (min 1024, max 65535)

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info                 # pino log level: trace, debug, info, warn, error, fatal
# LOG_ROTATION_SIZE=10M          # Rotate agent logs at this size
# LOG_ROTATION_MAX_FILES=5       # Rotated log files to keep (min 1, max 100)
# LOG_ROTATION_COMPRESS=true     # gzip-compress rotated logs
# LOG_RETENTION_DAYS=30          # Delete logs older than this (min 1, max 365)

# ── Timezone ─────────────────────────────────────────────────────────────────
# TZ=                            # Timezone for scheduled tasks (uses system default)
