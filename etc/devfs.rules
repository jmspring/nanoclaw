# NanoClaw jail devfs ruleset
# Restricts device exposure to prevent jail escape via kernel bugs
#
# This ruleset limits device access to only essential devices needed for
# basic operation. It explicitly denies access to dangerous devices like:
# - /dev/mem, /dev/kmem (direct memory access)
# - /dev/io (raw I/O port access)
# - /dev/bpf* (packet capture)
# - /dev/mdN (memory disk devices)
#
# Usage: Apply this ruleset in /etc/devfs.rules on the host system
# Then reference it in jail creation with devfs_ruleset=10

[nanoclaw_jail=10]
# Start with the standard jail ruleset (hides dangerous devices by default)
add include $devfsrules_jail
# Explicitly unhide only the devices we need
add path 'random' unhide
add path 'urandom' unhide
add path 'null' unhide
add path 'zero' unhide
add path 'stdin' unhide
add path 'stdout' unhide
add path 'stderr' unhide
add path 'fd' unhide
add path 'fd/*' unhide
add path 'pts' unhide
add path 'pts/*' unhide
